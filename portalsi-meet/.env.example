# =====================================================
# PortalSI Meet — Environment Template
# Copy to .env dan isi nilainya
# =====================================================

# Public URL WebSocket LiveKit yang client pakai (WAJIB https/wss di production)
# Contoh: wss://livekit.meet.example.com
NEXT_PUBLIC_LIVEKIT_URL=wss://livekit.yourdomain.com

# API Key & Secret LiveKit (generate sendiri, min 32 chars untuk secret)
# Generate via: openssl rand -hex 16   (API key)
# Generate via: openssl rand -hex 32   (secret)
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Redis URL (untuk setup Docker Compose default, biarkan apa adanya)
REDIS_URL=redis://redis:6379

# coturn TURN server
PUBLIC_IP=YOUR_VPS_PUBLIC_IP
TURN_REALM=meet.yourdomain.com
TURN_USER=portalsi
TURN_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT_MIN_24_CHARS

# Optional — Node env
NODE_ENV=production
